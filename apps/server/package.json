{
  "name": "@enbi/server",
  "version": "0.0.0",
  "description": "Hono content API for enbi.",
  "homepage": "https://enbi-cms.com",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./main": "./dist/main.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
