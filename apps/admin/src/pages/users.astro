---
import Admin from "../layouts/Admin.astro";
---
<Admin title="Users — enbi" active="/users">
  <h1>Users</h1>
  <p class="error" id="err" hidden></p>
  <div style="overflow-x:auto;">
    <table>
      <thead>
        <tr>
          <th>Email</th>
          <th>Role</th>
          <th>Change role</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="rows"></tbody>
    </table>
  </div>
  <script>
    import { enbiFetch, escapeHtml } from "../lib/api.ts";
    const rowsEl = document.getElementById("rows");
    const errEl = document.getElementById("err");
    const showErr = (m: string) => { if (errEl) { errEl.hidden = false; errEl.textContent = m; } };

    async function load() {
      const res = await enbiFetch("/api/admin_auth/admin/list-users");
      if (res.status === 401) { location.href = "/login"; return; }
      if (!res.ok) { showErr(`Failed to load users (${res.status}).`); return; }
      const data = (await res.json()) as { users: { id: string; email: string; name: string; role: string }[]; total: number };
      if (rowsEl) {
        rowsEl.innerHTML = data.users
          .map((u) =>
            `<tr>
              <td style="font-family:var(--font-body);font-size:0.9rem;color:var(--ink);">${escapeHtml(u.email)}</td>
              <td>${escapeHtml(u.role)}</td>
              <td><input type="text" data-userid="${escapeHtml(u.id)}" value="${escapeHtml(u.role)}" style="max-width:10rem;margin:0;padding:0.3rem 0.5rem;" /></td>
              <td><button data-userid="${escapeHtml(u.id)}" style="margin:0;padding:0.3rem 0.6rem;font-size:0.8rem;">Save</button></td>
            </tr>`)
          .join("");
        rowsEl.querySelectorAll<HTMLButtonElement>("button").forEach((btn) => {
          btn.addEventListener("click", async () => {
            const userId = btn.dataset.userid ?? "";
            const input = rowsEl.querySelector<HTMLInputElement>(`input[data-userid="${CSS.escape(userId)}"]`);
            const role = input ? input.value : "";
            const saveRes = await enbiFetch("/api/admin_auth/admin/set-role", {
              method: "POST",
              body: JSON.stringify({ userId, role }),
            });
            if (saveRes.status === 401) { location.href = "/login"; return; }
            if (saveRes.ok) { location.reload(); }
            else { showErr(`Save failed (${saveRes.status}).`); }
          });
        });
      }
    }
    void load();
  </script>
</Admin>
