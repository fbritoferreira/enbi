---
import Admin from "../layouts/Admin.astro";
---
<Admin title="Media — enbi" active="/media">
  <h1>Media</h1>
  <form id="upload" style="margin-bottom:1.5rem;">
    <label for="file">File</label>
    <input id="file" type="file" style="display:block;margin-top:0.3rem;" />
    <button type="submit">Upload</button>
  </form>
  <p id="msg" style="font-size:0.875rem;color:var(--muted);"></p>
  <div style="overflow-x:auto;">
    <table>
      <thead><tr><th>filename</th><th>mime</th><th>size</th><th>link</th><th></th></tr></thead>
      <tbody id="rows"></tbody>
    </table>
  </div>
  <script>
    import { enbiFetch, escapeHtml, apiBase } from "../lib/api.ts";
    const rowsEl = document.getElementById("rows");
    const msgEl = document.getElementById("msg");
    async function load() {
      const res = await enbiFetch("/api/admin_media");
      if (res.status === 401) { location.href = "/login"; return; }
      const items = (await res.json()) as { id: string; filename: string; mime: string; size: number }[];
      if (rowsEl) {
        rowsEl.innerHTML = items
          .map((m) =>
            `<tr>
              <td style="font-family:var(--font-body);font-size:0.9rem;color:var(--ink);">${escapeHtml(m.filename)}</td>
              <td style="font-family:var(--font-mono);font-size:0.75rem;">${escapeHtml(m.mime)}</td>
              <td style="font-family:var(--font-mono);font-size:0.8rem;">${escapeHtml(m.size)}</td>
              <td><a href="${escapeHtml(apiBase())}/api/media/${escapeHtml(m.id)}" target="_blank">open</a></td>
              <td><button data-id="${escapeHtml(m.id)}" style="margin:0;padding:0.25rem 0.6rem;font-size:0.8rem;color:var(--danger);border-color:var(--danger);">delete</button></td>
            </tr>`)
          .join("");
        rowsEl.querySelectorAll<HTMLButtonElement>("button").forEach((b) =>
          b.addEventListener("click", async () => {
            await enbiFetch(`/api/admin_media/${encodeURIComponent(b.dataset.id ?? "")}`, { method: "DELETE" });
            void load();
          }),
        );
      }
    }
    const uploadForm = document.getElementById("upload");
    uploadForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const input = document.getElementById("file") as HTMLInputElement;
      const f = input.files?.[0];
      if (!f) return;
      const form = new FormData();
      form.append("file", f);
      const res = await fetch(`${apiBase()}/api/admin_media`, {
        method: "POST",
        credentials: "include",
        body: form,
      });
      if (res.ok) {
        if (msgEl) msgEl.textContent = "Uploaded.";
        input.value = "";
        void load();
      } else {
        if (msgEl) msgEl.textContent = `Upload failed (${res.status.toString()}).`;
      }
    });
    void load();
  </script>
</Admin>
