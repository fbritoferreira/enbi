---
import Admin from "../layouts/Admin.astro";
---
<Admin title="Edit — enbi">
  <h1 id="heading">Entry</h1>
  <p id="hist-link" hidden><a id="hist-a" href="#">History</a></p>
  <button id="publish-toggle" hidden></button>
  <form id="form"></form>
  <button id="del" hidden>Delete</button>
  <p class="error" id="err" hidden></p>
  <script>
    import { enbiFetch, escapeHtml } from "../lib/api.ts";
    const sp = new URLSearchParams(location.search);
    const name = sp.get("c") ?? "";
    const id = sp.get("id") ?? "new";
    const isNew = id === "new";

    const heading = document.getElementById("heading");
    if (heading) heading.textContent = isNew ? `New ${name}` : `Edit ${name}/${id}`;

    const histLink = document.getElementById("hist-link");
    const histA = document.getElementById("hist-a") as HTMLAnchorElement | null;
    if (!isNew && histLink && histA) {
      histLink.hidden = false;
      histA.href = `/revisions?c=${encodeURIComponent(name)}&id=${encodeURIComponent(id)}`;
    }

    const form = document.getElementById("form") as HTMLFormElement | null;
    const errEl = document.getElementById("err");

    const showErr = (m: string) => {
      if (errEl) { errEl.hidden = false; errEl.textContent = m; }
    };

    const metaRes = await enbiFetch("/api/admin_collections");
    if (metaRes.status !== 401) {
      type FieldRule = { required?: boolean; [key: string]: unknown };
      type ColMeta = {
        name: string;
        primaryKey: string;
        columns: { name: string; type: string }[];
        drafts: { column: string } | false;
        relations: Record<string, { collection: string }>;
        validate: Record<string, FieldRule>;
        localized: string[];
      };
      type AdminCollectionsPayload = {
        collections: ColMeta[];
        locales: string[];
        defaultLocale: string | undefined;
      };

      const payload = (await metaRes.json()) as AdminCollectionsPayload;
      // Support both old (array) and new (object) response shapes gracefully.
      const allMeta: ColMeta[] = Array.isArray(payload) ? payload : (payload.collections ?? []);
      const configuredLocales: string[] = Array.isArray(payload) ? [] : (payload.locales ?? []);
      const defaultLocale: string = Array.isArray(payload) ? "en" : (payload.defaultLocale ?? (configuredLocales[0] ?? ""));

      const col = allMeta.find((m) => m.name === name);

      if (!col || !form) {
        showErr("Collection not found.");
      } else {
        let current: Record<string, unknown> = {};
        if (!isNew) {
          const r = await enbiFetch(`/api/${name}/${encodeURIComponent(id)}`);
          if (r.ok) current = await r.json() as Record<string, unknown>;
        }

        // ── Locale switcher ────────────────────────────────────────────────────
        let activeLocale = defaultLocale;
        let currentTranslations: Record<string, string> = {};

        const hasLocales = configuredLocales.length > 0 && col.localized.length > 0 && !isNew;
        if (hasLocales) {
          const localeContainer = document.createElement("div");
          localeContainer.id = "locale-switcher";
          let opts = "";
          for (const loc of configuredLocales) {
            opts += `<option value="${escapeHtml(loc)}"${loc === defaultLocale ? " selected" : ""}>${escapeHtml(loc)}</option>`;
          }
          localeContainer.innerHTML = `<label for="locale-select">Locale: </label><select id="locale-select">${opts}</select>`;
          form.parentElement?.insertBefore(localeContainer, form);

          const localeSelect = document.getElementById("locale-select") as HTMLSelectElement | null;
          if (localeSelect) {
            localeSelect.addEventListener("change", async () => {
              activeLocale = localeSelect.value;
              if (activeLocale !== defaultLocale) {
                const tRes = await enbiFetch(`/api/${name}/${encodeURIComponent(id)}/translations/${encodeURIComponent(activeLocale)}`);
                if (tRes.ok) {
                  currentTranslations = await tRes.json() as Record<string, string>;
                } else {
                  currentTranslations = {};
                }
              } else {
                currentTranslations = {};
              }
              // Repopulate localized fields with translation values (or base values).
              for (const fieldName of col.localized) {
                const input = document.getElementById(`f_${fieldName}`) as HTMLInputElement | null;
                if (input) {
                  if (activeLocale !== defaultLocale && Object.prototype.hasOwnProperty.call(currentTranslations, fieldName)) {
                    input.value = currentTranslations[fieldName];
                  } else {
                    input.value = String(current[fieldName] ?? "");
                  }
                }
              }
            });
          }
        }

        // ── Form fields ────────────────────────────────────────────────────────
        const parts: string[] = [];
        for (const c of col.columns) {
          const isRelation = Boolean(col.relations[c.name]);
          const isPk = c.name === col.primaryKey;
          const isRequired = Boolean(col.validate[c.name]?.required);
          const labelText = escapeHtml(c.name) + (isRequired ? " *" : "");
          if (isRelation && !isPk) {
            const targetName = col.relations[c.name].collection;
            let opts = `<option value="">-- none --</option>`;
            try {
              const tr = await enbiFetch(`/api/${encodeURIComponent(targetName)}?limit=100`);
              if (tr.ok) {
                const entries = (await tr.json()) as Record<string, unknown>[];
                const pkField = allMeta.find((m) => m.name === targetName)?.primaryKey ?? Object.keys(entries[0] ?? {})[0];
                for (const entry of entries) {
                  const idVal = escapeHtml(String(entry[pkField] ?? ""));
                  const labelVal = escapeHtml(String((entry as Record<string, unknown>).title ?? Object.values(entry as Record<string, unknown>)[0] ?? ""));
                  const sel = String(current[c.name] ?? "") === String(entry[pkField] ?? "") ? " selected" : "";
                  opts += `<option value="${idVal}"${sel}>${labelVal}</option>`;
                }
              }
            } catch { /* leave as empty select on network error */ }
            parts.push(
              `<label for="f_${escapeHtml(c.name)}">${labelText}</label><select id="f_${escapeHtml(c.name)}" name="${escapeHtml(c.name)}">${opts}</select>`,
            );
          } else {
            parts.push(
              `<label for="f_${escapeHtml(c.name)}">${labelText}</label><input id="f_${escapeHtml(c.name)}" name="${escapeHtml(c.name)}" value="${escapeHtml(current[c.name])}" ${isPk && !isNew ? "readonly" : ""} />`,
            );
          }
        }
        form.innerHTML = parts.join("") + `<button type="submit">Save</button>`;

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          if (!isNew && hasLocales && activeLocale !== defaultLocale) {
            // Non-default locale: write only localized fields via translations PUT.
            const translationBody: Record<string, string> = {};
            for (const fieldName of col.localized) {
              const input = document.getElementById(`f_${fieldName}`) as HTMLInputElement | null;
              if (input) translationBody[fieldName] = input.value;
            }
            const res = await enbiFetch(`/api/${name}/${encodeURIComponent(id)}/translations/${encodeURIComponent(activeLocale)}`, {
              method: "PUT",
              body: JSON.stringify(translationBody),
            });
            if (res.ok) {
              location.href = `/entries?c=${encodeURIComponent(name)}`;
            } else {
              showErr(`Save translations failed (${res.status}).`);
            }
          } else {
            // Default locale (or no i18n): write base row as before.
            const body: Record<string, string> = {};
            for (const c of col.columns) {
              const input = document.getElementById(`f_${c.name}`) as HTMLInputElement | null;
              body[c.name] = input ? input.value : "";
            }
            const res = isNew
              ? await enbiFetch(`/api/${name}`, { method: "POST", body: JSON.stringify(body) })
              : await enbiFetch(`/api/${name}/${encodeURIComponent(id)}`, { method: "PUT", body: JSON.stringify(body) });
            if (res.ok) {
              location.href = `/entries?c=${encodeURIComponent(name)}`;
            } else {
              showErr(`Save failed (${res.status}).`);
            }
          }
        });

        // Publish/Unpublish toggle
        const toggleBtn = document.getElementById("publish-toggle") as HTMLButtonElement | null;
        if (!isNew && col.drafts && toggleBtn) {
          const statusCol = col.drafts.column;
          const currentStatus = String(current[statusCol] ?? "draft");
          const isPublished = currentStatus === "published";
          toggleBtn.hidden = false;
          toggleBtn.textContent = isPublished ? "Unpublish" : "Publish";
          toggleBtn.addEventListener("click", async () => {
            const nextStatus = isPublished ? "draft" : "published";
            const body: Record<string, string> = {};
            for (const c of col.columns) {
              const input = document.getElementById(`f_${c.name}`) as HTMLInputElement | null;
              body[c.name] = c.name === statusCol ? nextStatus : (input ? input.value : String(current[c.name] ?? ""));
            }
            const res = await enbiFetch(`/api/${name}/${encodeURIComponent(id)}`, {
              method: "PUT",
              body: JSON.stringify(body),
            });
            if (res.ok) {
              location.href = `/entries?c=${encodeURIComponent(name)}`;
            } else {
              showErr(`Status update failed (${res.status}).`);
            }
          });
        }

        const del = document.getElementById("del") as HTMLButtonElement | null;
        if (!isNew && del) {
          del.hidden = false;
          del.addEventListener("click", async () => {
            const res = await enbiFetch(`/api/${name}/${encodeURIComponent(id)}`, { method: "DELETE" });
            if (res.ok) {
              location.href = `/entries?c=${encodeURIComponent(name)}`;
            } else {
              showErr(`Delete failed (${res.status}).`);
            }
          });
        }
      }
    } else {
      location.href = "/login";
    }
  </script>
</Admin>
