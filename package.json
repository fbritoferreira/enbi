{
  "name": "enbi",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-2.0-only",
  "type": "module",
  "scripts": {
    "ready": "vp run -r build && vp check && vp run -r test",
    "dev": "vp run -r --parallel dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm publish -r --no-git-checks",
    "e2e": "playwright test",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@changesets/changelog-git": "catalog:",
    "@changesets/cli": "catalog:",
    "@enbi/db": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "drizzle-orm": "catalog:",
    "testcontainers": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.7.0"
}
